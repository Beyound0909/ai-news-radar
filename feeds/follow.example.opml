    <!-- 加密货币 / Crypto -->
    <outline text="Crypto / 加密货币">
      <outline
        text="CoinDesk"
        title="CoinDesk"
        type="rss"
        xmlUrl="https://www.coindesk.com/arc/outboundfeeds/rss"
        htmlUrl="https://www.coindesk.com/"
      />
      <outline
        text="CoinTelegraph"
        title="CoinTelegraph"
        type="rss"
        xmlUrl="https://cointelegraph.com/rss"
        htmlUrl="https://cointelegraph.com/"
      />
    </outline>

    <!-- 全球宏观 / Global Macro -->
    <outline text="Global Macro / 全球宏观">
      <outline
        text="Financial Times"
        title="Financial Times"
        type="rss"
        xmlUrl="https://www.ft.com/rss/home"
        htmlUrl="https://www.ft.com/"
      />
    </outline>

    <!-- AI + Tech (retained from original) -->
    <outline text="AI and Tech">
      <outline
        text="OpenAI News"
        title="OpenAI News"
        type="rss"
        xmlUrl="https://openai.com/news/rss.xml"

<?xml version="1.0" encoding="UTF-8"?>
<opml version="2.0">
  <head>
    <title>Finance News Radar RSS</title>
  </head>
  <body>
    <!-- A股 / China A-Shares -->
    <outline text="A-Stocks / A股">
      <outline
        text="东方财富网"
        title="东方财富网"
        type="rss"
        xmlUrl="https://feed.eastmoney.com/"
        htmlUrl="https://www.eastmoney.com/"
      />
      <outline
        text="新浪财经"
        title="新浪财经"
        type="rss"
        xmlUrl="https://rss.sina.com.cn/"
        htmlUrl="https://finance.sina.com.cn/"
      />
      <outline
        text="36氪"
        title="36氪"
        type="rss"
        xmlUrl="https://36kr.com/feed"
        htmlUrl="https://36kr.com/"
      />
    </outline>

    <!-- 港股 / HK Stocks -->
    <outline text="HK Stocks / 港股">
      <outline
        text="AASTOCKS"
        title="AASTOCKS"
        type="rss"
        xmlUrl="https://www.aastocks.com/tc/stocks/rss/aafn-news.xml"
        htmlUrl="https://www.aastocks.com/"
      />
    </outline>

    <!-- 美股 / US Stocks -->
    <outline text="US Stocks / 美股">
      <outline
        text="MarketWatch Top Stories"
        title="MarketWatch Top Stories"
        type="rss"
        xmlUrl="https://www.marketwatch.com/rss/topstories"
        htmlUrl="https://www.marketwatch.com/"
      />
      <outline
        text="MarketWatch Market Pulse"
        title="MarketWatch Market Pulse"
        type="rss"
        xmlUrl="https://www.marketwatch.com/rss/marketpulse"
        htmlUrl="https://www.marketwatch.com/"
      />
      <outline
        text="CNBC News"
        title="CNBC News"
        type="rss"
        xmlUrl="https://www.cnbc.com/id/100003114/device/rss/rss.html"
        htmlUrl="https://www.cnbc.com/"
      />
      <outline
        text="Nasdaq RSS"
        title="Nasdaq RSS"
        type="rss"
        xmlUrl="https://www.nasdaq.com/feed/rssoutbound"
        htmlUrl="https://www.nasdaq.com/"
      />
      <outline
        text="Yahoo Finance"
        title="Yahoo Finance"
        type="rss"
        xmlUrl="https://finance.yahoo.com/news/rssindex"
        htmlUrl="https://finance.yahoo.com/"
